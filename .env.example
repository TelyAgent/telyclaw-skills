# ClawHub configuration
# Copy this file to .env and fill in your values

# Default owner/organization handle (e.g. @telyclaw)
# Overridable via --owner flag
CLAWHUB_OWNER=@your-org

# ClawHub registry URL (optional, defaults to clawhub.ai)
# CLAWHUB_REGISTRY=https://clawhub.ai

# Working directory for sync (optional, defaults to repo root)
# CLAWHUB_WORKDIR=.
